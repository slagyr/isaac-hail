{:id :isaac.hail,
 :version "0.1.8",
 :builtin? true,
 :factory isaac.hail.module/create-module,
 :isaac.agent/tools
 {:hail-send {:factory isaac.tool.hail/hail-send-tool-factory}
  :hail-get  {:factory isaac.tool.hail-get/hail-get-tool-factory}},
 :isaac/cli
 {:hail
  {:usage "hail <subcommand> [options]",
   :summary "Produce hail records",
   :namespace isaac.hail.cli}},
 :isaac.server/route
 [{:method :post,
   :path "/hail/send",
   :handler isaac.hail.http/handler}],
 :isaac.config/schema
 {:hail-settings
  {:schema
   {:name :hail-settings,
    :type :map,
    :description "Hail queue settings",
    :schema
    {:naming-strategy
     {:type :keyword,
      :description "Hail id naming strategy: :short-uuid (default), :uuid, or :sequential",
      :validations [[:one-of? :short-uuid :uuid :sequential]]},
     :max-continuations
     {:type :int,
      :description "Max loop-limit continuations per delivery before dead-letter (default 3)",
      :validations [:positive?]}}}}
  :hail
  {:entity-dir "hail",
   :frontmatter? true,
   :merge-root-entity? true,
   :companion {:field :prompt, :mode :optional},
   :schema
   {:name :hail,
    :type :map,
    :snapshot-only? true,
    :description "Hail band declarations",
    :key-spec {:type :string},
    :value-spec
    {:name :hail-band,
     :type :map,
     :description "Hail band declaration",
     :schema
     {:addressing
      {:type :ignore,
       :description "Derived: bands must address sessions (or declare :base for inheritance)",
       :validations
       [[:requires-any? :session :session-tags :crew :base]]},
      :base
      {:type :string,
       :description "Optional base band template (file stem) to inherit from"},
      :crew
      {:type :string,
       :description "Sessions whose :crew matches this id are eligible",
       :validations [[:nil-or? [:crew-exists?]]]},
      :prompt
      {:type :string,
       :description "Optional companion markdown prompt for the band"},
      :reach
      {:type :keyword,
       :description "How many listeners receive the hail",
       :validations [[:one-of? :one :all]]},
      :create
      {:type :keyword,
       :description "Create policy when :reach is :one and no matching session is available (:never or :if-missing).",
       :validations [[:one-of? :never :if-missing]]},
      :data
      {:type :map,
       :description "Band-level data delivered with every hail (merged with per-hail :params)",
       :key-spec {:type :keyword},
       :value-spec {:type :any}},
      :session
      {:type :seq,
       :description "Explicit session ids eligible for the band",
       :spec {:type :string}},
      :session-tags
      {:type :seq,
       :description "Tags sessions must carry",
       :spec {:type :keyword}},
      :with-crew
      {:type :string,
       :description "Override crew for deliveries on this band",
       :validations [[:nil-or? [:crew-exists?]]]},
      :with-model
      {:type :string,
       :description "Override model for deliveries on this band",
       :validations [[:nil-or? [:model-exists?]]]},
      :with-effort
      {:type :int,
       :description "Override effort for deliveries on this band"},
      :with-context-mode
      {:type :keyword,
       :description "Override context mode for deliveries on this band"}}}}}}
 :isaac.config/check
 {:hail-band-inheritance {:fn isaac.hail.band-resolve/check-config}}}